{
  "permissions": {
    "allow": [
      "mcp__Salesforce_DX__*",
      "mcp__slack__slack_*",
      "Bash",
      "Edit",
      "Write",
      "Agent"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-startup.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
