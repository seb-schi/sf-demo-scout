{
  "permissions": {
    "allow": [
      "Bash(sf config *)",
      "Bash(sf org *)",
      "Bash(sf data *)",
      "Bash(sf project *)",
      "Bash(sf template *)",
      "Bash(sf agent *)",
      "Bash(osascript -e *)",
      "Bash(ls *)",
      "Bash(mv *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(python3 *)",
      "Bash(python3)",
      "Bash(wc -l *)",
      "Bash(bash .claude/scripts/sync-skills.sh)",
      "Bash(bash .claude/scripts/sync-skills.sh *)",
      "Bash(bash .claude/scripts/sync-skills.sh | *)",
      "mcp__Salesforce_DX__run_soql_query",
      "mcp__Salesforce_DX__retrieve_metadata",
      "mcp__Salesforce_DX__deploy_metadata",
      "mcp__Salesforce_DX__assign_permission_set",
      "mcp__Salesforce_DX__list_all_orgs",
      "mcp__Salesforce_DX__run_code_analyzer",
      "mcp__Salesforce_DX__get_username",
      "Edit",
      "Write",
      "Agent"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-startup.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
